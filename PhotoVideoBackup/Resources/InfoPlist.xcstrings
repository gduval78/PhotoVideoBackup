      "comment" : "Privacy - Local Network Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PhotoVideoBackup verbindet sich mit Ihrem NAS im lokalen Netzwerk, um Fotos und Videos zu sichern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PhotoVideoBackup connects to your NAS on the local network to back up photos and videos."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PhotoVideoBackup se conecta a tu NAS en la red local para hacer copias de tus fotos y vídeos."
