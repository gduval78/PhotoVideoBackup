    "Not enough free space on this device. This backup needs %@ but only %@ is available. Free up space and try again.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht genügend freier Speicher auf diesem Gerät. Diese Sicherung benötigt %1$@, es sind aber nur %2$@ verfügbar. Geben Sie Speicher frei und versuchen Sie es erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay espacio suficiente en este dispositivo. Esta copia de seguridad necesita %1$@, pero solo hay %2$@ disponibles. Libera espacio e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Espace insuffisant sur cet appareil. Cette sauvegarde nécessite %1$@ alors que seulement %2$@ sont disponibles. Libérez de l’espace puis réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Spazio insufficiente su questo dispositivo. Questo backup richiede %1$@ ma sono disponibili solo %2$@. Libera spazio e riprova."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Espaço insuficiente neste dispositivo. Esta cópia de segurança precisa de %1$@, mas só há %2$@ disponíveis. Liberte espaço e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Недостаточно свободного места на устройстве. Для этой резервной копии требуется %1$@, доступно только %2$@. Освободите место и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备可用空间不足。此次备份需要 %1$@，但仅有 %2$@ 可用。请释放空间后重试。"
          }
        }
      }
    },
