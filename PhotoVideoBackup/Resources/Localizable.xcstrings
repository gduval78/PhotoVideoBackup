    "\"%@\" is not connected. Reconnect the SD card and try again.": {
      "comment": "Error when external source is offline",
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@“ ist nicht verbunden. SD-Karte erneut verbinden und versuchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" is not connected. Reconnect the SD card and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» no está conectado. Vuelva a conectar la tarjeta SD e intente de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %@ » n'est pas connecté. Reconnectez la carte SD et réessayez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" non è connesso. Ricollega la scheda SD e riprova."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" não está conectado. Reconecte o cartão SD e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" не подключён. Подключите карту SD и повторите попытку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\"未连接。请重新连接 SD 卡后重试。"
