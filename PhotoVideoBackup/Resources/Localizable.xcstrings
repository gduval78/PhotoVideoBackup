    "You appear to be on mobile data. Backing up to the NAS may use your data plan — tap Stop to halt it.": {
      "comment": "A warning that a mobile data connection is detected when backing up to a NAS.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie sind offenbar im Mobilfunknetz. Das Backup auf das NAS kann Ihr Datenvolumen verbrauchen — tippen Sie auf Stopp, um es anzuhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You appear to be on mobile data. Backing up to the NAS may use your data plan — tap Stop to halt it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que estás usando datos móviles. La copia al NAS puede consumir tu plan de datos — toca Detener para pararla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous semblez être en données mobiles. La sauvegarde vers le NAS peut consommer votre forfait — appuyez sur Stop pour l’arrêter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sembri essere su rete mobile. Il backup sul NAS può consumare il tuo piano dati — tocca Stop per interromperlo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que está a usar dados móveis. A cópia para o NAS pode consumir o seu plano de dados — toque em Parar para a interromper."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Похоже, вы используете мобильные данные. Резервное копирование на NAS может расходовать трафик — нажмите «Стоп», чтобы остановить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您似乎正在使用移动数据。备份到 NAS 可能会消耗您的流量 — 点按“停止”以中止。"
          }
        }
      }
    },
